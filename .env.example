# Azure Cosmos DB for NoSQL
COSMOSDB_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOSDB_KEY=replace-with-your-cosmos-key
COSMOSDB_DATABASE=todaytrack

# App auth
APP_BASE_URL=http://localhost:3000
# Microsoft Entra ID OAuth
AZURE_OAUTH_CLIENT_ID=replace-with-your-microsoft-client-id
AZURE_OAUTH_CLIENT_SECRET=replace-with-your-microsoft-client-secret
AZURE_OAUTH_AUTHORIZE_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/authorize
AZURE_OAUTH_TOKEN_URL=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
AZURE_OAUTH_JWKS_URL=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
AZURE_OAUTH_SCOPE=openid profile email
AZURE_OAUTH_DOMAIN_HINT=
# Optional strict issuer check
AZURE_OAUTH_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-your-google-client-secret
GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_OAUTH_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
GOOGLE_OAUTH_SCOPE=openid email profile
GOOGLE_OAUTH_ISSUER=https://accounts.google.com
